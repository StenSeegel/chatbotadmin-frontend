# Base URL for the chatbot widget (where widget.js is hosted).
# IMPORTANT: widget.js calls /api/* on the SAME origin it was loaded from, so
# this must point at a host that serves both widget.js AND proxies /api/.
# For production: https://ki-chat.uni-giessen.de
# For local Docker stack (local-frontend): http://localhost:8081
VITE_WIDGET_BASE_URL=https://ki-chat.uni-giessen.de

# Server-side only (NO VITE_ prefix → never bundled into the browser).
# Used by the /api/chat proxy (vite.config.ts in dev, server/index.mjs in prod)
# to call the HRZ (Uni Gießen) OpenAI-compatible endpoint via openai-node.
KI_API_KEY=
KI_BASE_URL=https://api.hrz.uni-giessen.de/v1

# CORS: origins allowed to call /api/* from the browser (the embedded widget
# runs on a different origin than the backend). Comma-separated, exact match —
# never "*". Example for multiple Plone origins:
#   CORS_ALLOWED_ORIGINS=https://www.uni-giessen.de,https://uni-giessen.de
# In the Vite dev proxy any http(s)://localhost[:port] origin is also allowed.
CORS_ALLOWED_ORIGINS=https://www.uni-giessen.de

# Rate limiting for /api/* in the backend (defense-in-depth; Nginx also limits).
# Max requests per window per client IP. Defaults: 30 requests / 60000 ms.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Where the backend persists widget configurations (source of truth for both the
# admin panel and the embedded widget.js). Default: ./data/widgets.json next to
# the store module. In Docker this points at a mounted volume.
# WIDGETS_FILE=/app/data/widgets.json
