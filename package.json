{
  "name": "chatbotadmin-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run backend:up && docker compose --profile local up -d widget-test-site && vite",
    "dev:frontend": "vite",
    "backend:up": "docker compose -f go-backend/docker-compose.yml up -d --build",
    "backend:down": "docker compose -f go-backend/docker-compose.yml down",
    "backend:logs": "docker compose -f go-backend/docker-compose.yml logs -f backend",
    "build": "npm run build:widget-assets && tsc -b && vite build",
    "build:widget-assets": "node scripts/generate-widget-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:api-types": "openapi-typescript go-backend/internal/apidocs/openapi.yaml -o src/types/api.gen.ts",
    "lint:api-spec": "npx --yes @redocly/cli@2 lint go-backend/internal/apidocs/openapi.yaml"
  },
  "dependencies": {
    "@ki4jlu/design-system": "^0.20.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
