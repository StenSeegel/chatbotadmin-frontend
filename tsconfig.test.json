{
  /* Type-checking project for the test suite. The app project (tsconfig.app.json)
   * excludes *.test.* and src/test, so without this config the IDE has no project
   * that covers the tests — jest-dom matchers (toBeInTheDocument, toHaveValue, …)
   * then appear untyped. Including src/test/setup.ts loads the
   * "@testing-library/jest-dom/vitest" augmentation for vitest's expect. */
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    /* node: the widget integration test reads public/widget.js via node:fs. */
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test"],
  "exclude": []
}
